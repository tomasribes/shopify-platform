# ─── Shopify CLI ───────────────────────────────────────────────────────────────
# Optional: Partners API token for CI/non-interactive environments
# Get it from: https://partners.shopify.com → Settings → Partner API clients
SHOPIFY_CLI_PARTNERS_TOKEN=

# ─── App credentials (auto-generated after 'make init') ───────────────────────
# These will be populated in app/.env by the CLI after initialization
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
